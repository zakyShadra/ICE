{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Backend (tsx)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@ice/backend", "dev"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "restart": true
    },
    {
      "type": "dart",
      "request": "launch",
      "name": "Flutter Mobile (Android)",
      "cwd": "${workspaceFolder}/apps/mobile",
      "program": "lib/main.dart"
    }
  ]
}
