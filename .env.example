# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# --- Database (Prisma) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ice?schema=public
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/ice?schema=public

# --- Backend ---
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# --- AI Providers (all optional — Router degrades to whichever are configured) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
QWEN_API_KEY=
OPENROUTER_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
